# Server Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/smart-farming
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ML Models
DISEASE_DETECTION_MODEL_PATH=./models/disease-detection.h5
CROP_RECOMMENDATION_MODEL_PATH=./models/crop-recommendation.pkl
PRICE_PREDICTION_MODEL_PATH=./models/price-prediction.h5
YIELD_FORECASTING_MODEL_PATH=./models/yield-forecasting.pkl

# Weather API
OPENWEATHER_API_KEY=your_openweather_api_key
WEATHER_API_ENDPOINT=https://api.openweathermap.org/data/2.5

# Satellite API
SATELLITE_API_KEY=your_satellite_api_key
SENTINEL_HUB_KEY=your_sentinel_hub_key

# SMS/Email Services
TWILLIO_ACCOUNT_SID=your_twilio_account_sid
TWILLIO_AUTH_TOKEN=your_twilio_auth_token
TWILLIO_PHONE_NUMBER=your_twilio_phone

SENDGRID_API_KEY=your_sendgrid_api_key
MAIL_FROM=noreply@smartfarming.com

# Voice Assistant Services
GOOGLE_CLOUD_PROJECT_ID=your_google_cloud_project
GOOGLE_CLOUD_KEY_FILE=./config/google-cloud-key.json

# Admin Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_in_production

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# CORS
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# IoT Configuration
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=mqtt_user
MQTT_PASSWORD=mqtt_password
